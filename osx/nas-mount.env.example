# Copy to ~/.config/nas-mount.env and fill in the values for your network.
# The real file is machine-local and MUST NOT be committed. chmod 600 it —
# these are LAN details, not secrets (Keychain holds the SMB password).

NAS_HOST="192.168.1.2"
NAS_USER="yourname"
NAS_SHARE="data"

# Optional overrides — defaults shown:
# NAS_MOUNT_POINT="/Volumes/${NAS_SHARE}"
# NAS_SENTINEL="${NAS_MOUNT_POINT}/documents"
